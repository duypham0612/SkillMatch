@model IEnumerable<SkillMatch.Models.Job>

@{
    ViewData["Title"] = "Trung tâm Tìm kiếm Việc làm Sinh viên";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold text-primary">💼 Khám phá cơ hội việc làm</h2>
            <p class="text-muted">Tìm các dự án phù hợp với kỹ năng Edit Video, PowerPoint, Design của bạn.</p>
        </div>
        <div class="col-md-4 align-self-center">
            <form action="@Url.Action("Index", "Jobs")" method="get" class="d-flex">
                <input type="text" name="searchString" class="form-control me-2" placeholder="Nhập từ khóa tìm việc..." />
                <button type="submit" class="btn btn-primary">Tìm</button>
            </form>
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model.Where(j => j.Status == "Open"))
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0 rounded-3">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-success-subtle text-success font-monospace">@item.Status</span>
                            <small class="text-muted">⏳ @item.Deadline.ToString("dd/MM/yyyy")</small>
                        </div>
                        <h5 class="card-title fw-bold text-dark text-truncate">@item.Title</h5>
                        <p class="card-text text-muted text-truncate-2 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @item.Description
                        </p>
                        <div class="mt-3 pt-3 border-top d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-muted small">Ngân sách:</span>
                                <span class="text-danger fw-bold d-block">@string.Format("{0:N0}", item.Budget) đ</span>
                            </div>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm px-3 rounded-pill">Xem Chi Tiết</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>