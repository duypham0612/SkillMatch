<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkillMatch</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SkillMatch.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 py-2">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill"></i> SkillMatch
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold me-2" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold me-2" asp-area="" asp-controller="Jobs" asp-action="Index"><i class="bi bi-briefcase"></i> Việc làm SkillMatch</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-semibold me-2" asp-controller="Student" asp-action="Index"><i class="bi bi-person-badge"></i> Hồ sơ của tôi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-semibold me-2" asp-controller="Student" asp-action="MyApplications">
                                    <i class="bi bi-send-check"></i> Việc đã ứng tuyển
                                </a>
                            </li>
                        }

                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Client"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-semibold me-2" asp-controller="Jobs" asp-action="Create"><i class="bi bi-plus-circle"></i> Đăng việc mới</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-success fw-semibold me-2" asp-controller="Jobs" asp-action="Index"><i class="bi bi-kanban"></i> Quản lý dự án</a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link text-muted small" asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link text-dark me-3">
                                    Chào, <span class="text-primary fw-bold">@User.Identity.Name</span>
                                    <span class="badge @(User.IsInRole("Client") ? "bg-success" : "bg-primary") font-monospace ms-1 small">
                                        @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                    </span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-danger btn-sm px-3" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-semibold px-3" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-success btn-sm text-white px-3 fw-bold ms-2" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-3">
        <div class="container text-center">
            &copy; 2026 - <strong>SkillMatch Project</strong> - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Chính sách bảo mật hệ thống</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>